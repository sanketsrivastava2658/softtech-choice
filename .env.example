# ── App ───────────────────────────────────────────────────────────────
# Public base URL — used to build invite / set-password links. Set to your
# real domain in production (e.g. https://app.softtechchoice.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (auth + multi-tenant data) ───────────────────────────────
# From Supabase dashboard → Project Settings → API.
# Public (browser-safe) — used by the client + middleware:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by the sync job to write cached data (bypasses RLS).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Smartlead (MASTER / agency key) ───────────────────────────────────
# Your agency's master API key (Settings → API). Needs the white-label
# "client management" feature so the app can call /client/save per client.
# Preferred: set it in-app at Admin → Credentials (stored in app_settings).
# This env var is the fallback if Supabase isn't configured. Unset = demo data.
SMARTLEAD_API_KEY=your-smartlead-master-api-key
# Override only if you use a regional/proxy base URL:
# SMARTLEAD_BASE_URL=https://server.smartlead.ai/api/v1

# NOTE: With NONE of these set, the app runs in open "demo mode" with seeded
# mock data and no login wall — useful for local UI work.
